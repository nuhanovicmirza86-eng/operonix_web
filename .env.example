# Upitnik / assessment — slanje e-maila (bar jedan način)
# Preporučeno (Firebase): zapis u Firestore + e-mail vlasniku + autoodgovor korisniku
# U Vercel / hosting: puni URL HTTP funkcije (npr. iz Firebase console) + ista tajna kao u Firebase
OPERONIX_QUOTE_FUNCTION_URL=
OPERONIX_QUOTE_INGEST_SECRET=

# Web3Forms: https://web3forms.com — Access Key, bez kartice, na vaš e-mail
WEB3FORMS_ACCESS_KEY=

# Ili Resend: https://resend.com
RESEND_API_KEY=
# Primatelji (zarez ili tačka-zarez) — ako prazno, koriste se operonix zadane adrese u kodu
ASSESSMENT_TO_EMAIL=nuhanovic.mirza86@gmail.com,info@operonixindustrial.com
# Pošiljalac (Resend: verifikovana domena)
RESEND_FROM=Operonix <upitnik@vasadomena.com>
